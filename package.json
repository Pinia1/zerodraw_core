{
  "name": "zeroDraw",
  "scripts": {
    "dev": "turbo dev",
    "dev:ai": "packages/ai-render/.venv/Scripts/python.exe packages/ai-render/server.py",
    "dev:full": "concurrently -n turbo,ai-render -c cyan,magenta \"turbo dev\" \"packages/ai-render/.venv/Scripts/python.exe packages/ai-render/server.py\"",
    "dev:web": "turbo dev --filter=@zeroDraw/web",
    "dev:api": "turbo dev --filter=@zeroDraw/api",
    "dev:docs": "turbo dev --filter=@zeroDraw/docs",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.1.0",
    "turbo": "^2.9.6",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
