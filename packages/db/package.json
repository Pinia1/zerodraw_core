{
  "name": "@zeroDraw/db",
  "version": "1.0.0",
  "description": "Drizzle ORM schemas and database utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsx src/test.ts",
    "db:generate": "node scripts/run-drizzle.js generate",
    "db:migrate": "node scripts/run-drizzle.js migrate",
    "db:push": "node scripts/run-drizzle.js push",
    "db:studio": "node scripts/run-drizzle.js studio",
    "db:export": "cd scripts && export.bat",
    "db:export:full": "cd scripts && export.bat full",
    "db:export:schema": "cd scripts && export.bat schema",
    "db:export:data": "cd scripts && export.bat data",
    "db:export:all": "cd scripts && export.bat all",
    "db:import": "cd scripts && import.bat"
  },
  "keywords": [
    "drizzle",
    "orm",
    "mysql",
    "database"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "mysql2": "^3.11.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  }
}
